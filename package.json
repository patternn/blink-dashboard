{
  "name": "blink-dashboard",
  "version": "0.2.0",
  "description": "Real-time Blink metrics dashboard — reads from BigQuery, zero prod DB load",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "jobs:aggregate": "tsx src/jobs/aggregate.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^7.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.5",
    "winston": "^3.14.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
