# ============================================
# Blink Dashboard — BigQuery Edition
# ============================================

# --- Server ---
PORT=3100
NODE_ENV=development

# --- Google BigQuery ---
GOOGLE_APPLICATION_CREDENTIALS=./credentials/blink-bigquery-key.json
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=galoy_production

# --- Table names (update with actual schema) ---
BIGQUERY_TABLE_ACCOUNTS=accounts
BIGQUERY_TABLE_TRANSACTIONS=transactions
BIGQUERY_TABLE_WALLETS=wallets

# --- Field mappings (update with actual schema) ---
BIGQUERY_FIELD_ACCOUNT_ID=id
BIGQUERY_FIELD_ACCOUNT_CREATED_AT=created_at
BIGQUERY_FIELD_ACCOUNT_PHONE=phone
BIGQUERY_FIELD_ACCOUNT_STATUS=status

BIGQUERY_FIELD_TX_ID=id
BIGQUERY_FIELD_TX_ACCOUNT_ID=account_id
BIGQUERY_FIELD_TX_CREATED_AT=created_at
BIGQUERY_FIELD_TX_STATUS=status

BIGQUERY_FIELD_WALLET_ID=id
BIGQUERY_FIELD_WALLET_CURRENCY=currency
BIGQUERY_FIELD_WALLET_BALANCE=balance

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Aggregation ---
AGGREGATION_INTERVAL_SECONDS=60

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
