# ============================================
# Blink Dashboard — Environment Configuration
# ============================================

# --- Server ---
PORT=3100
NODE_ENV=development

# --- Galoy Admin GraphQL API ---
# The admin API endpoint for your Galoy/Blink instance
# Typically: https://admin-api.yourdomain.com/graphql
GALOY_ADMIN_API_URL=https://admin-api.blink.sv/graphql
GALOY_ADMIN_AUTH_TOKEN=

# --- Galoy Public GraphQL API ---
GALOY_PUBLIC_API_URL=https://api.blink.sv/graphql
GALOY_API_KEY=blink_xxx

# --- MongoDB (Galoy backend database) ---
# Direct read-only access for aggregate queries
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=galoy

# --- Redis (caching layer) ---
REDIS_URL=redis://localhost:6379

# --- Bria (on-chain liquidity) ---
# Optional: for BTC custody balance from on-chain wallets
BRIA_API_URL=
BRIA_API_KEY=

# --- Aggregation ---
# How often to refresh metrics (in seconds)
AGGREGATION_INTERVAL_SECONDS=30

# --- CORS ---
CORS_ORIGIN=http://localhost:5173
